<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <!--
        PENTING: ID fragment di sini harus SAMA PERSIS
        dengan ID item di menu_bottom_nav.xml.
        Itulah cara NavigationUI menghubungkan tab dengan Fragment.
    -->

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.watchwatch.app.ui.HomeFragment"
        android:label="Home">
        <!-- Aksi navigasi dari Home ke List Review -->
        <action
            android:id="@+id/action_home_to_listReview"
            app:destination="@id/listReviewFragment" />
    </fragment>

    <fragment
        android:id="@+id/categoryFragment"
        android:name="com.watchwatch.app.ui.CategoryFragment"
        android:label="Kategori">
        <!-- Aksi navigasi dari Kategori ke List Review -->
        <action
            android:id="@+id/action_category_to_listReview"
            app:destination="@id/listReviewFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.watchwatch.app.ui.SearchFragment"
        android:label="Search" />

    <fragment
        android:id="@+id/bookmarkFragment"
        android:name="com.watchwatch.app.ui.BookmarkFragment"
        android:label="Bookmark" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.watchwatch.app.ui.SettingsFragment"
        android:label="Settings" />

    <!--
        ListReviewFragment bukan tab di BottomNav,
        melainkan halaman yang dibuka dari Home atau Kategori.
        Menerima data kategori via Bundle (categoryId & categoryName).
    -->
    <fragment
        android:id="@+id/listReviewFragment"
        android:name="com.watchwatch.app.ui.ListReviewFragment"
        android:label="List Review" />

</navigation>
